# =============================================================================
# Contract API — Environment Configuration
# Copy this to .env and fill in your values
# =============================================================================

# --- Server ---
SERVER_PORT=8080
API_KEY=your-api-key-here
# TESTING_MODE=true          # Set to true to disable auth (dev only)

# --- MySQL (required) ---
# go-sql-driver DSN; parseTime is added automatically if omitted
# Local docker-compose (docker compose up -d): root / root, DB contract_api
MYSQL_DSN=root:root@tcp(127.0.0.1:3306)/contract_api?parseTime=true
# Other installs: use a real user/password that exists in MySQL (not the old "user:password" placeholder)

# --- Aptos ---
APTOS_NODE_URL=https://api.testnet.aptoslabs.com/v1
APTOS_CHAIN_ID=2             # 2=testnet, 1=mainnet
# Optional: API key sent as `Authorization: Bearer <APTOS_API_KEY>` on every
# request to APTOS_NODE_URL. Strongly recommended for any production or CI use
# — the public endpoint rate-limits per IP and will 429 under load.
# APTOS_API_KEY=aptoslabs_xxx

# --- Circle ---
CIRCLE_API_KEY=your-circle-api-key
CIRCLE_ENTITY_SECRET=your-32-byte-hex-entity-secret
CIRCLE_WALLET_SET_ID=your-wallet-setid

## --- Webhook (optional) ---
# WEBHOOK_URL=https://your-server.com/webhook

# --- Transaction Settings ---
MAX_GAS_AMOUNT=2000000
TXN_EXPIRATION_SECONDS=60
POLL_INTERVAL_SECONDS=5
