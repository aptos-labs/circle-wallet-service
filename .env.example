# JioCoin API — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# ─── Server ───────────────────────────────────────────────────────────────────

# HTTP port to listen on (default: 8080)
SERVER_PORT=8080

# API key required in Authorization header for all mutating requests.
# Leave blank only if TESTING_MODE=true.
API_KEY=

# Disable authentication and generate ephemeral keys for all roles.
# NEVER enable in production.
TESTING_MODE=false

# ─── Aptos ────────────────────────────────────────────────────────────────────

# Aptos node RPC endpoint.
# Testnet: https://api.testnet.aptoslabs.com/v1
# Devnet:  https://api.devnet.aptoslabs.com/v1
# Mainnet: https://api.mainnet.aptoslabs.com/v1
APTOS_NODE_URL=https://api.testnet.aptoslabs.com/v1

# Chain ID for the target network (2 = testnet, 177 = devnet, 1 = mainnet).
APTOS_CHAIN_ID=2

# Deployed JioCoin contract address (the account that published the package).
JIOCOIN_CONTRACT_ADDRESS=

# ─── Signer Provider ──────────────────────────────────────────────────────────

# "local" — sign with private keys below (development / testing)
# "circle" — sign via Circle Programmable Wallets (production)
SIGNER_PROVIDER=local

# ─── Local Signer (SIGNER_PROVIDER=local) ─────────────────────────────────────
# Hex-encoded Ed25519 private keys for each role.
# Addresses are derived automatically from the private key.
# Leave blank for roles that are not used.

MINTER_PRIVATE_KEY=
DENYLISTER_PRIVATE_KEY=
MASTER_MINTER_PRIVATE_KEY=
METADATA_UPDATER_PRIVATE_KEY=
OWNER_PRIVATE_KEY=

# ─── Circle Signer (SIGNER_PROVIDER=circle) ───────────────────────────────────

# API key from the Circle Developer Console (console.circle.com).
CIRCLE_API_KEY=

# Entity Secret — 32-byte random hex value generated once during Circle account setup.
# The server encrypts this with Circle's RSA public key at startup automatically.
#
# Generate and register it with:
#   node --env-file=.env --import=tsx dev-controlled-wallets/register-entity-secret.ts
CIRCLE_ENTITY_SECRET=

# Per-role Circle wallet IDs.
# Create wallets via the Circle API:
#   POST https://api.circle.com/v1/w3s/developer/wallets
#   Body: { "blockchains": ["APTOS-TESTNET"], "count": 1, "entitySecretCiphertext": "...", "walletSetId": "..." }
MINTER_WALLET_ID=
DENYLISTER_WALLET_ID=
MASTER_MINTER_WALLET_ID=
METADATA_UPDATER_WALLET_ID=
OWNER_WALLET_ID=

# Per-role Aptos addresses (returned by Circle wallet creation response).
MINTER_ADDRESS=
DENYLISTER_ADDRESS=
MASTER_MINTER_ADDRESS=
METADATA_UPDATER_ADDRESS=
OWNER_ADDRESS=

# Per-role Ed25519 public keys for the Circle wallets (hex, with 0x prefix).
#
# Circle does NOT expose wallet public keys via their API. Obtain them either:
#   1. From the Circle Developer Console (check the wallet detail page)
#   2. From on-chain transaction history once the wallet has submitted a tx:
#        ./scripts/get-aptos-pubkey.sh 0xYOUR_WALLET_ADDRESS
#
# Each key is 32 bytes / 64 hex chars, e.g.: 0xabcdef1234...
MINTER_PUBLIC_KEY=
DENYLISTER_PUBLIC_KEY=
MASTER_MINTER_PUBLIC_KEY=
METADATA_UPDATER_PUBLIC_KEY=
OWNER_PUBLIC_KEY=

# ─── SQLite ───────────────────────────────────────────────────────────────────

# Path to the SQLite database file.
SQLITE_PATH=./jiocoin.db

# ─── Transaction Settings ─────────────────────────────────────────────────────

# Maximum number of retry attempts for failed transactions (default: 3).
MAX_RETRIES=3

# How often the poller checks for pending transactions, in seconds (default: 5).
POLL_INTERVAL_SECONDS=5

# Maximum number of recipients in a single batch-mint request (default: 500).
MAX_BATCH_SIZE=500

# Maximum gas units per transaction (default: 100000).
MAX_GAS_AMOUNT=100000

# Fixed gas units per recipient in batch-mint (0 = use estimate, default: 0).
GAS_PER_RECIPIENT=0

# Seconds before an unconfirmed transaction is considered expired (default: 60).
TXN_EXPIRATION_SECONDS=60

# Retry backoff: initial wait in seconds before the first retry (default: 10).
RETRY_BACKOFF_BASE_SECONDS=10

# Retry backoff: maximum wait in seconds between retries (default: 300).
RETRY_BACKOFF_MAX_SECONDS=300
